    "Orders": {
      "createOrder": {
        "method": "POST",
        "path": "/orders",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER", "STAFF", "CUSTOMER"],
        "body": {
          "customerName": "string",
          "customerPhone": "string",
          "items": [
            {
              "itemType": "string (required)",
              "quantity": "number (required, > 0)",
              "unitPrice": "number (required, >= 0)"
            }
          ],
          "pickupDate": "date (required, future date)",
          "deliveryDate": "date (optional)",
          "priority": "string (NORMAL|EXPRESS|URGENT)",
          "discount": "number (0-100%)",
          "totalAmount": "number",
          "branchId": "string (required for admin)"
        }
      },
      "getAllOrders": {
        "method": "GET",
        "path": "/orders",
        "auth": true,
        "queryParams": {
          "status": { "type": "string", "enum": ["RECEIVED", "PROCESSING", "READY", "DELIVERED", "CANCELLED"] },
          "paymentStatus": { "type": "string", "enum": ["PAID", "UNPAID"] },
          "search": { "type": "string", "description": "Order number or customer name" },
          "page": { "type": "number", "default": 1 },
          "limit": { "type": "number", "default": 10, "max": 100 }
        }
      },
      "getSingleOrder": {
        "method": "GET",
        "path": "/orders/:orderId",
        "auth": true,
        "pathParams": { "orderId": "string (ObjectId)" }
      },
      "updateOrder": {
        "method": "PUT",
        "path": "/orders/:orderId",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "pathParams": { "orderId": "string" },
        "body": "any order fields"
      },
      "markOrderPaid": {
        "method": "PUT",
        "path": "/orders/:orderId/mark-paid",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "pathParams": { "orderId": "string" },
        "body": {}
      },
      "updateOrderStatus": {
        "method": "PATCH",
        "path": "/orders/:orderId/status",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER", "STAFF"],
        "pathParams": { "orderId": "string" },
        "body": {
          "status": "string (RECEIVED|PROCESSING|READY|DELIVERED|CANCELLED)"
