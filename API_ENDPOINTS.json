{
  "version": "2.0",
  "baseURL": "http://localhost:3000/api/v1",
  "authentication": "JWT Bearer Token in Authorization header",
  "lastUpdated": "2026-04-09",
  "analytics": {
    "note": "All analytics endpoints now use live queries directly from the database for real-time accuracy. No pre-computed analytics storage is required."
  },
  "endpoints": {
    "Dashboard": {
      "getDashboardSummary": {
        "method": "GET",
        "path": "/analytics/dashboard",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "queryParams": {
          "branchId": { "type": "string", "required": false, "description": "For SUPER_ADMIN to filter by branch" }
        },
        "response": {
          "totalOrders": "number",
          "totalRevenue": "number",
          "totalCustomers": "number",
          "ordersByStatus": "object",
          "branchLeaderboard": "array"
        }
      },
      "getPeriodAnalytics": {
        "method": "GET",
        "path": "/analytics/period",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "queryParams": {
          "startDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "endDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "branchId": { "type": "string", "required": false }
        }
      },
      "getDailyAnalytics": {
        "method": "GET",
        "path": "/analytics/daily",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "queryParams": {
          "date": { "type": "string", "required": false, "format": "YYYY-MM-DD", "note": "defaults to today" },
          "branchId": { "type": "string", "required": false }
        }
      },
      "getOrderTrends": {
        "method": "GET",
        "path": "/analytics/orders/trends",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "queryParams": {
          "startDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "endDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "branchId": { "type": "string", "required": false }
        }
      },
      "getRevenueAnalytics": {
        "method": "GET",
        "path": "/analytics/revenue",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "queryParams": {
          "startDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "endDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "branchId": { "type": "string", "required": false }
        }
      },
      "getCustomerAnalytics": {
        "method": "GET",
        "path": "/analytics/customers",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "queryParams": {
          "startDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "endDate": { "type": "string", "required": true, "format": "YYYY-MM-DD" },
          "branchId": { "type": "string", "required": false }
        }
      },
      "exportDashboardPDF": {
        "method": "POST",
        "path": "/analytics/export/pdf",
        "auth": true,
        "roles": ["SUPER_ADMIN", "BRANCH_MANAGER"],
        "body": {
          "dashboardData": "object",
          "dateRange": { "startDate": "string", "endDate": "string" }
        },
        "response": "PDF file"
      }
    },
    "Authentication": {
      "register": {
        "method": "POST",
        "path": "/auth/sign-up",
        "auth": false,
        "body": {
          "fullname": "string",
          "email": "email",
          "phoneNumber": "string",
          "password": "string (min 8 chars, uppercase, lowercase, number, special char)",
          "confirmPassword": "string",
          "role": "string (SUPER_ADMIN|BRANCH_MANAGER|STAFF|CUSTOMER)"
        },
        "response": {
          "user": "object",
          "accessToken": "string",
          "refreshToken": "string"
        }
      },
      "login": {
        "method": "POST",
        "path": "/auth/login",
        "auth": false,
        "body": {
          "email": "email",
          "password": "string"
        },
        "response": {
          "user": "object",
          "accessToken": "string",
          "refreshToken": "string"
        }
      },
      "refreshToken": {
        "method": "POST",
        "path": "/auth/refresh-token",
        "auth": false,
        "body": {
          "refreshToken": "string"
        },
        "response": {
          "accessToken": "string",
          "refreshToken": "string"
        }
      },
      "logout": {
        "method": "POST",
        "path": "/auth/logout",
        "auth": true,
        "body": {
          "refreshToken": "string"
        }
      },
      "forgotPassword": {
        "method": "POST",
        "path": "/auth/forgot-password",
        "auth": false,
        "body": {
          "email": "email"
        }
      },
      "resetPassword": {
        "method": "PATCH",
        "path": "/auth/reset-password/:token",
        "auth": false,
        "body": {
          "password": "string (min 8 chars)",
          "confirmPassword": "string"
        }
      },
      "changePassword": {
        "method": "PATCH",
        "path": "/auth/change-password",
        "auth": true,
        "body": {
          "currentPassword": "string",
          "newPassword": "string (min 8 chars, uppercase, lowercase, number, special char)",
          "confirmPassword": "string"
        },
        "response": {
          "success": "boolean",
          "message": "string"
        }
      }
    },
    "System": {
      "healthCheck": {
        "method": "GET",
